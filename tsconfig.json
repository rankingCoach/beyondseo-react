{
    "compilerOptions": {
        "allowJs": true,
        "outDir": "./dist/out-tsc",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "strict": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "skipLibCheck": true,
        "paths": {
            "@src/*": ["src/*"],
            "@models/*": ["src/models/*"],
            "@components/*": ["src/components/*"],
            "@stores/*": ["src/stores/*"],
            "@helpers/*": ["src/helpers/*"],
            "@hooks/*": ["src/custom-hooks/*"],
            "@assets/*": ["src/assets/*"],
            "@contexts/*": ["src/contexts/*"],
            "vanguard": ["node_modules/@rankingcoach/vanguard"],
            "vanguard/*": ["node_modules/@rankingcoach/vanguard/*"]
        }
    },
    "include": [
        "src/**/*",
        "src/globals.d.ts"
    ]
}
